# ── Market Analysis Agent ─────────────────────────────────────────────
# Défaut : mode démo sans clé API (LLM simulé, déterministe)
LLM_PROVIDER=mock

# ── Groq (gratuit, rapide) ────────────────────────────────────────────
# LLM_PROVIDER=groq
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_API_KEY=gsk_...

# ── DeepSeek (très peu coûteux) ───────────────────────────────────────
# LLM_PROVIDER=deepseek
# LLM_MODEL=deepseek-chat
# LLM_API_KEY=sk-...

# ── OpenRouter (accès multi-modèles) ──────────────────────────────────
# LLM_PROVIDER=openrouter
# LLM_MODEL=meta-llama/llama-3.3-70b-instruct
# LLM_API_KEY=sk-or-...

# ── OpenAI ────────────────────────────────────────────────────────────
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# LLM_API_KEY=sk-...

# ── Anthropic (natif) ─────────────────────────────────────────────────
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-haiku-4-5
# LLM_API_KEY=sk-ant-...

# ── Ollama local (aucune clé) ─────────────────────────────────────────
# LLM_PROVIDER=ollama
# LLM_MODEL=llama3.2

# ── Endpoint OpenAI-compatible custom ────────────────────────────────
# LLM_PROVIDER=custom
# LLM_BASE_URL=https://mon-gateway.local/v1
# LLM_MODEL=mon-modele
# LLM_API_KEY=...

# ── Contrôle qualité (LLM-as-judge) ──────────────────────────────────
JUDGE_ENABLED=true
JUDGE_THRESHOLD=0.7

# ── Estimation de coût (optionnel, $ par million de tokens) ──────────
# LLM_PRICE_IN_PER_MTOK=1.0
# LLM_PRICE_OUT_PER_MTOK=5.0
